# InstaLoop Environment Configuration
# Copie este arquivo para .env e preencha com seus valores

# ===========================================
# BANCO DE DADOS
# ===========================================
DATABASE_URL=postgresql://username:password@localhost:5432/instaloop

# ===========================================
# JWT - SEGURANÇA CRÍTICA
# ===========================================
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=SEU_JWT_SECRET_KEY_DE_256_BITS_AQUI
JWT_ACCESS_TOKEN_EXPIRES=900        # 15 minutos
JWT_REFRESH_TOKEN_EXPIRES=604800    # 7 dias

# ===========================================
# ADMIN - SEGURANÇA CRÍTICA
# ===========================================
# Rota secreta para painel admin (ex: x7k2m9p4, abc123xyz, etc.)
ADMIN_ROUTE_SECRET=ROTA_SECRETA_ADMIN_AQUI

# ===========================================
# ARGON2 - CONFIGURAÇÃO DE HASH
# ===========================================
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=2

# ===========================================
# UPLOADS - CONFIGURAÇÃO
# ===========================================
UPLOAD_MAX_SIZE_MB=5
UPLOAD_DIR=static/uploads

# ===========================================
# RATE LIMITING
# ===========================================
RATELIMIT_STORAGE_URL=redis://localhost:6379

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# SEGURANÇA GERAL
# ===========================================
SECRET_KEY=SEU_SECRET_KEY_DE_256_BITS_AQUI
FLASK_ENV=development

# ===========================================
# FRONTEND
# ===========================================
VITE_ADMIN_ROUTE=MESMA_ROTA_SECRETA_ADMIN_AQUI
VITE_API_URL=http://localhost:5000

# ===========================================
# ALERTAS (OPCIONAL)
# ===========================================
# Webhook para alertas de segurança em tempo real
# Exemplo: https://hooks.slack.com/services/XXXXX/YYYYY/ZZZZZ
HONEYPOT_WEBHOOK_URL=SEU_WEBHOOK_URL_AQUI

# ===========================================
# REDIS (PARA RATE LIMITING E CACHE)
# ===========================================
REDIS_URL=redis://localhost:6379/0

# ===========================================
# EMAIL (PARA RECUPERAÇÃO DE SENHA)
# ===========================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=seu_email@gmail.com
MAIL_PASSWORD=sua_app_password
MAIL_DEFAULT_SENDER=InstaLoop <noreply@instaloop.com>

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO
LOG_FILE=logs/instaloop.log

# ===========================================
# DESENVOLVIMENTO
# ===========================================
DEBUG=True
TESTING=False
